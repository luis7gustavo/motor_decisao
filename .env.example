# Motor de Decisao de Compra - ambiente local

ENVIRONMENT=development
LOG_LEVEL=INFO

# Postgres local do motor
MOTOR_POSTGRES_USER=motor
MOTOR_POSTGRES_PASSWORD=motor
MOTOR_POSTGRES_DB=motor_decisao
MOTOR_POSTGRES_PORT=55432

# Redis local do motor
MOTOR_REDIS_PORT=6380

# Selenium Grid local
SELENIUM_PORT=4444
SELENIUM_NOVNC_PORT=7900
SELENIUM_REMOTE_URL=http://selenium:4444/wd/hub
# 2026-05-02: match the Bronze parallel fan-out expected by the safer scraper sources.
SELENIUM_MAX_SESSIONS=4

# API local do motor
MOTOR_API_PORT=8010

# Usadas dentro dos containers
DATABASE_URL=postgresql+psycopg://motor:motor@postgres:5432/motor_decisao
REDIS_URL=redis://redis:6379/0
MOTOR_CONFIG_PATH=/app/config/config.yaml

# Discord
DISCORD_WEBHOOK_URL=

# Mercado Livre
ML_API_BASE=https://api.mercadolibre.com
ML_AUTH_BASE=https://auth.mercadolivre.com.br
ML_SITE_ID=MLB
ML_CLIENT_ID=
ML_CLIENT_SECRET=
ML_REDIRECT_URI=
ML_ACCESS_TOKEN=
ML_REFRESH_TOKEN=
